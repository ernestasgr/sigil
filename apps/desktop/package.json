{
    "name": "@sigil/desktop",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "description": "Sigil desktop application — Electron shell, Automation Engine worker, and React renderer.",
    "main": "./out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "pretest": "pnpm run native:setup && pnpm run native:check",
        "test": "vitest run",
        "test:renderer": "vitest run src/renderer",
        "test:native": "pnpm run native:setup && pnpm run native:check && vitest run",
        "native:setup": "pnpm rebuild better-sqlite3",
        "native:check": "tsx scripts/check-native-sqlite.ts",
        "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
        "predev": "electron-rebuild -f -w better-sqlite3",
        "prebuild": "electron-rebuild -f -w better-sqlite3"
    },
    "dependencies": {
        "@sigil/schema": "workspace:*",
        "@xyflow/react": "12.11.0",
        "better-sqlite3": "12.11.1",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "drizzle-orm": "0.45.2",
        "effect": "^3.21.4",
        "esbuild": "^0.28.1",
        "lucide-react": "1.21.0",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "rxjs": "7.8.2",
        "tailwind-merge": "3.6.0",
        "tsx": "^4.22.4",
        "zod": "4.4.3",
        "zustand": "5.0.14"
    },
    "devDependencies": {
        "@electron/rebuild": "4.0.4",
        "@tailwindcss/vite": "4.3.1",
        "@types/better-sqlite3": "7.6.13",
        "@types/node": "26.0.0",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "5.2.0",
        "electron": "42.4.1",
        "electron-vite": "5.0.0",
        "tailwindcss": "4.3.1",
        "tw-animate-css": "1.4.0",
        "typescript": "^6.0.3",
        "vite": "7.3.5",
        "vitest": "4.1.9"
    }
}
