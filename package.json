{
    "name": "sigil",
    "private": true,
    "version": "0.0.0",
    "description": "A local-first desktop automation platform that reacts to system events by executing user-defined workflows.",
    "type": "module",
    "packageManager": "pnpm@11.8.0",
    "engines": {
        "node": ">=24.15.0 <25"
    },
    "scripts": {
        "preinstall": "node scripts/check-node-version.mjs",
        "start": "pnpm run dev",
        "predev": "node scripts/check-node-version.mjs",
        "dev": "node scripts/dev.mjs",
        "prebuild": "node scripts/check-node-version.mjs",
        "build": "pnpm --filter @sigil/schema build && pnpm --filter @sigil/desktop build",
        "preview": "pnpm --filter @sigil/desktop preview",
        "pretypecheck": "node scripts/check-node-version.mjs",
        "typecheck": "pnpm -r typecheck",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "format:check": "biome check --formatter-enabled=true --linter-enabled=false --assist-enabled=false .",
        "architecture:check": "depcruise apps/desktop/src packages/schema/src --config .dependency-cruiser.json --output-type err-long --progress none",
        "structure:check": "pnpm exec ast-grep scan --config sgconfig.yml --filter=guard- --color=never --report-style=medium --warning=no-suppress-all --warning=unused-suppression",
        "structure:check:json": "pnpm exec ast-grep scan --config sgconfig.yml --filter=guard- --color=never --json=compact --include-metadata --threads=1 --warning=no-suppress-all --warning=unused-suppression",
        "structure:test": "pnpm exec ast-grep test --config sgconfig.yml --color=never",
        "structure:codemod": "pnpm exec ast-grep scan --config sgconfig.yml --filter=codemod- --color=never --report-style=medium",
        "structure:codemod:write": "pnpm exec ast-grep scan --config sgconfig.yml --filter=codemod- --color=never --report-style=medium --update-all",
        "knip": "knip --no-exit-code --reporter compact",
        "knip:report": "knip --no-exit-code --reporter json",
        "knip:baseline": "knip --no-exit-code --reporter markdown",
        "check:fast": "pnpm lint && pnpm format:check && pnpm architecture:check && pnpm structure:check && pnpm structure:test && pnpm workflows:check && pnpm typecheck && pnpm test:fast",
        "pretest": "node scripts/check-node-version.mjs",
        "test:node": "node --test scripts/node-version-contract.test.mjs scripts/dev-orchestrator.test.mjs",
        "test:fast": "pnpm test:node && pnpm --filter @sigil/schema test && pnpm --filter @sigil/desktop test:renderer",
        "pretest:fast": "node scripts/check-node-version.mjs",
        "test:e2e": "pnpm --filter @sigil/schema build && pnpm --filter @sigil/desktop build && pnpm --filter @sigil/desktop test:e2e",
        "test:coverage": "pnpm --filter @sigil/schema test:coverage && pnpm --filter @sigil/desktop test:coverage",
        "coverage": "pnpm test:coverage",
        "coverage:check": "tsx scripts/check-coverage-baseline.ts",
        "check:node": "node scripts/check-node-version.mjs",
        "check:coverage": "pnpm --filter @sigil/schema build && pnpm --filter @sigil/desktop native:setup && pnpm --filter @sigil/desktop native:check && pnpm test:coverage && pnpm coverage:check",
        "test:ui": "vitest --config vitest.config.ts --ui",
        "setup:native": "pnpm --filter @sigil/desktop native:setup",
        "check:native": "pnpm --filter @sigil/desktop native:check",
        "test:native": "pnpm --filter @sigil/desktop test:native",
        "verify:production": "pnpm --filter @sigil/desktop verify:production",
        "workflows:check": "node --experimental-strip-types scripts/validate-agent-workflows.ts",
        "test": "pnpm test:node && pnpm -r test",
        "test:watch": "pnpm --filter @sigil/schema test:watch",
        "clean": "pnpm -r --parallel exec rimraf dist out .turbo node_modules/.cache",
        "prepare": "husky"
    },
    "devDependencies": {
        "@ai-hero/sandcastle": "^0.10.0",
        "@ast-grep/cli": "0.44.1",
        "@biomejs/biome": "^2.5.3",
        "@types/node": "26.1.1",
        "@vitest/ui": "4.1.9",
        "dependency-cruiser": "18.0.0",
        "husky": "^9.1.7",
        "knip": "6.27.0",
        "lint-staged": "^17.0.7",
        "rimraf": "6.1.3",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "vitest": "4.1.9",
        "zod": "4.4.3"
    }
}
